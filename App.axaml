<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MovieTracker.App"
             RequestedThemeVariant="Dark">
    <!--
        RequestedThemeVariant="Dark" forteaza tema intunecata la nivel de aplicatie.
        FluentTheme ofera stilurile de baza pentru toate controalele Avalonia.
    -->
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
